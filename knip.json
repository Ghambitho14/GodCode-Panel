{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/main.tsx", "src/app.tsx"],
  "project": ["src/**/*.{js,jsx,ts,tsx}", "tests/**/*.{js,jsx,ts,tsx}"],
  "ignore": ["src/vite-env.d.ts", "src/modules/cash/admin/pages/Admin.d.ts"],
  "ignoreDependencies": ["@vercel/node"],
  "ignoreExportsUsedInFile": true,
  "vite": {
    "config": ["vite.config.ts"]
  },
  "vitest": {
    "config": ["vitest.config.ts"],
    "entry": ["tests/**/*.{test,spec}.{js,jsx,ts,tsx}"]
  },
  "playwright": {
    "config": ["playwright.config.ts"],
    "entry": ["tests/e2e/**/*.ts"]
  }
}
