# === OBLIGATORIAS ===

# Supabase (cliente navegador)
# En produccion/Coolify usar /api/supabase para que el trafico pase por el BFF
# y no se exponga Supabase al publico. En desarrollo local usar la URL directa.
VITE_SUPABASE_URL=/api/supabase
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# === OPCIONALES ===

# Service Role Key (solo necesaria para Edge Functions u operaciones server-only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Company slug para URLs del storefront
VITE_PUBLIC_COMPANY_SLUG=mi-empresa

# Activa logs de monitoreo en produccion ("1" = activado)
VITE_GC_MONITOR=0

# === SOLO PARA PRODUCCION / COOLIFY ===
# URL real e interna de Supabase (misma instancia o red de Docker).
# NUNCA debe ser relativa ni apuntar al dominio publico del frontend.
SUPABASE_INTERNAL_URL=http://127.0.0.1:54321/
SUPABASE_URL=http://127.0.0.1:54321/
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
