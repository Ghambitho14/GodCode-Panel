# === OBLIGATORIAS ===

# Supabase (cliente + server)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# === OPCIONALES ===

# Service Role Key (solo necesario para Edge Functions)
