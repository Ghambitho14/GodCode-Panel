# Copiar a `.env` (o `.env.local`) y completar — Vite solo expone variables con prefijo VITE_
#
# Supabase: Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# El panel admin ya no usa slug en env: la empresa sale de `public.users.company_id` tras login (Supabase Auth).

# Cloudinary (opcional; subida de imágenes)
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_UPLOAD_PRESET=
